# Normalize line endings for cross-platform consistency
* text=auto eol=lf

# Force LF for source code (Node.js + TypeScript)
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Windows batch files MUST be CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files (never modify)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
