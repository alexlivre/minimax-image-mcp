{
  "name": "minimax-image-mcp",
  "version": "1.0.2",
  "description": "MCP server for MiniMax image generation API",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint .",
    "coverage": "vitest run --coverage --passWithNoTests"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "minimax",
    "image-generation",
    "ai",
    "claude",
    "opencode",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexlivre/minimax-image-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/alexlivre/minimax-image-mcp/issues"
  },
  "homepage": "https://github.com/alexlivre/minimax-image-mcp#readme"
}
